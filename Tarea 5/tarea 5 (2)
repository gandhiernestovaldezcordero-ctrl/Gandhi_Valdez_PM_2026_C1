#include <stdio.h>

#define MAX_CADENA 256

int longitud_cadena(const char cadena[]) {
    int longitud = 0;

    while (cadena[longitud] != '\0' && cadena[longitud] != '\n') {
        longitud++;
    }

    return longitud;
}

int main(void) {
    char nombre_archivo[256];
    char cadena[MAX_CADENA];
    int mayor_longitud = 0;
    int se_leyo_cadena = 0;
    FILE *archivo;

    printf("Ingrese el nombre del archivo de texto: ");
    if (fgets(nombre_archivo, sizeof(nombre_archivo), stdin) == NULL) {
        printf("No fue posible leer el nombre del archivo.\n");
        return 1;
    }

    {
        int i = 0;
        while (nombre_archivo[i] != '\0') {
            if (nombre_archivo[i] == '\n') {
                nombre_archivo[i] = '\0';
                break;
            }
            i++;
        }
    }

    archivo = fopen(nombre_archivo, "r");
    if (archivo == NULL) {
        printf("No fue posible abrir el archivo.\n");
        return 1;
    }

    while (fgets(cadena, sizeof(cadena), archivo) != NULL) {
        int longitud_actual = longitud_cadena(cadena);

        if (longitud_actual > mayor_longitud) {
            mayor_longitud = longitud_actual;
        }

        se_leyo_cadena = 1;
    }

    fclose(archivo);

    if (se_leyo_cadena) {
        printf("La longitud de la cadena mas grande es: %d\n", mayor_longitud);
    } else {
        printf("El archivo esta vacio.\n");
    }

    return 0;
}
