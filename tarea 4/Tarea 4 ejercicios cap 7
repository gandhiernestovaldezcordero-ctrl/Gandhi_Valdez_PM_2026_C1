#include <stdio.h>
#include <string.h>

#define MAX_FILAS 20
#define MAX_LONGITUD 30

void limpiar_salto(char cadena[]) {
    size_t longitud = strlen(cadena);

    if (longitud > 0 && cadena[longitud - 1] == '\n') {
        cadena[longitud - 1] = '\0';
    }
}

void intercambia_filas(char fra[][MAX_LONGITUD], int n) {
    int i;
    int j = n - 1;
    char temporal[MAX_LONGITUD];

    for (i = 0; i < n / 2; i++) {
        strcpy(temporal, fra[i]);
        strcpy(fra[i], fra[j]);
        strcpy(fra[j], temporal);
        j--;
    }
}

int main(void) {
    int i;
    int n;
    char fra[MAX_FILAS][MAX_LONGITUD];

    printf("Ingrese el numero de filas del arreglo: ");
    if (scanf("%d", &n) != 1) {
        printf("Entrada invalida.\n");
        return 1;
    }

    if (n < 1 || n > MAX_FILAS) {
        printf("El numero de filas debe estar entre 1 y %d.\n", MAX_FILAS);
        return 1;
    }

    getchar();

    for (i = 0; i < n; i++) {
        printf("Ingrese la linea de texto numero %d: ", i + 1);
        if (fgets(fra[i], sizeof(fra[i]), stdin) == NULL) {
            printf("Error al leer la cadena.\n");
            return 1;
        }
        limpiar_salto(fra[i]);
    }

    intercambia_filas(fra, n);

    printf("\nArreglo con las filas intercambiadas:\n");
    for (i = 0; i < n; i++) {
        printf("Linea %d: %s\n", i + 1, fra[i]);
    }

    return 0;
}
